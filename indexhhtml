<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
<style>
/* CSSはご提示いただいたものをそのまま採用し、一部調整しています */
body { font-family: "Helvetica Neue", Arial, "Hiragino Kaku Gothic ProN", "Hiragino Sans", sans-serif; background-color: #f4f7f6; color: #333; margin: 0; padding: 10px; line-height: 1.6; -webkit-text-size-adjust: 100%; }
.container { max-width: 500px; margin: 0 auto; background: #fff; border-radius: 16px; box-shadow: 0 8px 24px rgba(0,0,0,0.05); padding: 20px; box-sizing: border-box; }
.title { color: #2ecc71; text-align: center; font-size: 1.4rem; margin-bottom: 24px; border-bottom: 3px solid #f0fdf4; padding-bottom: 12px; font-weight: bold; }
.ac-item { border: 2px solid #edf2f7; border-radius: 12px; padding: 18px; margin-bottom: 20px; background: #ffffff; }
.ac-header { font-weight: bold; color: #2ecc71; margin-bottom: 15px; display: block; font-size: 1.1rem; border-left: 5px solid #2ecc71; padding-left: 10px; }
.input-label { display: block; font-weight: bold; font-size: 0.95rem; margin: 15px 0 8px 0; color: #2d3748; }
.plan-images { display: flex; justify-content: space-between; align-items: stretch; gap: 8px; margin: 12px 0; }
.plan-card { width: 48%; text-align: center; cursor: pointer; border: 2px solid #e2e8f0; border-radius: 10px; overflow: hidden; transition: all 0.2s ease; display: flex; flex-direction: column; }
.plan-card img { width: 100%; height: 120px; object-fit: cover; display: block; }
.plan-card small { display: flex; align-items: center; justify-content: center; flex-grow: 1; padding: 8px 0; font-weight: bold; font-size: 0.85rem; background: #f8f9fa; line-height: 1.3; }
.plan-card.selected { border-color: #2ecc71; background-color: #f0fdf4; transform: translateY(-2px); box-shadow: 0 4px 12px rgba(46, 204, 113, 0.2); }
.plan-card.selected small { background: #2ecc71; color: #fff; }
.accordion-btn { display: flex; justify-content: space-between; align-items: center; background-color: #f8fafc; border: 1px solid #cbd5e0; border-radius: 8px; padding: 14px; font-weight: bold; color: #2d3748; cursor: pointer; margin-top: 25px; user-select: none; }
.accordion-btn::after { content: '▼'; font-size: 0.8rem; color: #718096; }
.accordion-btn.open::after { transform: rotate(180deg); }
.accordion-body { display: none; margin-top: 10px; }
.accordion-body.open { display: block; animation: fadeIn 0.3s ease; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(-5px); } to { opacity: 1; transform: translateY(0); } }
.option-list { display: flex; flex-direction: column; gap: 10px; }
.option-item { border: 1px solid #cbd5e0; border-radius: 8px; padding: 12px; display: flex; align-items: flex-start; cursor: pointer; background: #ffffff; }
.option-checkbox { margin-top: 2px; margin-right: 12px; width: 18px; height: 18px; }
.option-content { flex: 1; }
.option-title { font-weight: bold; color: #2d3748; display: flex; align-items: center; flex-wrap: wrap; font-size: 0.95rem; }
.option-price-black { margin-left: auto; color: #333; font-size: 0.95rem; }
.option-desc { font-size: 0.85rem; color: #4a5568; margin-top: 6px; }
.badge-popular { background: #e53e3e; color: white; font-size: 0.7rem; padding: 2px 6px; border-radius: 4px; margin-left: 8px; }
.consult-text-group { padding: 0 12px 12px 12px; background: #ffffff; border: 1px solid #cbd5e0; border-top: none; margin-top: -10px; }
select, input[type="text"], input[type="tel"], input[type="file"], textarea { width: 100%; padding: 14px; border: 1px solid #cbd5e0; border-radius: 8px; box-sizing: border-box; font-size: 1rem; }
.btn-add { width: 100%; background: #fff; color: #2ecc71; border: 2px solid #2ecc71; padding: 14px; border-radius: 10px; font-weight: bold; margin: 15px 0; cursor: pointer; }
.btn-main { width: 100%; background: #00c853; color: #fff; border: none; padding: 18px; border-radius: 12px; font-size: 1.1rem; font-weight: bold; cursor: pointer; margin-top: 12px; }
.btn-line { width: 100%; background: #06c755; color: #fff; border: none; padding: 18px; border-radius: 12px; font-size: 1.1rem; font-weight: bold; cursor: pointer; display: block; text-align: center; margin-top: 15px; }
.btn-pulse { animation: pulse 2s infinite ease-in-out; }
@keyframes pulse { 0% { transform: scale(1); } 50% { transform: scale(1.02); } 100% { transform: scale(1); } }
.info-box { background: #fff9c4; border-radius: 10px; padding: 15px; font-size: 0.9rem; margin: 15px 0; border: 1px solid #fef3c7; }
.quote-box { background: #f7fafc; padding: 18px; border-radius: 10px; border: 1px solid #edf2f7; margin-bottom: 15px; }
.total-display { text-align: center; font-size: 1.8rem; font-weight: bold; margin: 20px 0; color: #2d3748; }
.price-red { color: #e53e3e; }
.hidden { display: none; }
.btn-back { text-align: center; color: #718096; cursor: pointer; margin-top: 20px; font-size: 0.95rem; text-decoration: underline; display: block; }
.photo-section { background-color: #f0fdf4; border: 1px solid #c6f6d5; padding: 20px; border-radius: 12px; margin-top: 20px; }
.photo-label { font-weight: bold; display: block; margin-bottom: 8px; color: #166534; font-size: 1.05rem; }
.example-flex { display: flex; gap: 12px; overflow-x: auto; padding-bottom: 10px; }
.example-item { flex: 0 0 150px; text-align: center; }
.example-img { width: 100%; height: 150px; object-fit: cover; border-radius: 8px; }
.no-photo-check { margin-top: 15px; display: flex; align-items: center; cursor: pointer; font-weight: bold; }
.confirm-item { border-bottom: 1px dashed #cbd5e0; padding: 12px 0; display: flex; justify-content: space-between; font-size: 0.95rem; }
.confirm-label { color: #718096; font-weight: bold; }
.confirm-value { color: #2d3748; text-align: right; word-break: break-all; max-width: 60%; }
.date-input-row { display: flex; align-items: center; margin-bottom: 12px; }
.date-input-label { width: 80px; font-weight: bold; font-size: 0.9rem; color: #2d3748; }
</style>
</head>
<body>
<div class="container">
  <div id="step1">
    <h1 class="title">エアイブキ かんたん見積もり</h1>
    <div id="ac-list">
      <div class="ac-item" id="ac-block-1">
        <span class="ac-header">エアコン 1台目</span>
        <label class="input-label">エアコンのタイプ</label>
        <div class="plan-images">
          <div class="plan-card selected" id="card-normal-1" onclick="selectType(1,'normal')">
            <img src="https://i.imgur.com/rnfPxwk.jpg" alt="通常"><small>通常タイプ<br>14,500円</small>
          </div>
          <div class="plan-card" id="card-cleaning-1" onclick="selectType(1,'cleaning')">
            <img src="https://i.imgur.com/lgveI9e.jpg" alt="お掃除"><small>お掃除機能付き<br>21,500円</small>
          </div>
        </div>
        <select class="type-sel" id="sel-type-1" onchange="syncUI(1, this.value)">
          <option value="normal">通常タイプ 14,500円</option>
          <option value="cleaning">お掃除機能付き 21,500円</option>
          <option value="unknown">わからない</option>
        </select>
        <div class="accordion-btn" onclick="this.classList.toggle('open'); this.nextElementSibling.classList.toggle('open');">オプションを追加する</div>
        <div class="accordion-body">
          <div class="option-list">
            <label class="option-item"><input type="checkbox" class="option-checkbox" value="boukabi"><div class="option-content"><div class="option-title">防カビ加工 <span class="badge-popular">人気NO.1</span><span class="option-price-black">3,300円</span></div></div></label>
            <label class="option-item"><input type="checkbox" class="option-checkbox" value="drain"><div class="option-content"><div class="option-title">ドレンパン洗浄等 <span class="option-price-black">5,500円</span></div></div></label>
            <label class="option-item"><input type="checkbox" class="option-checkbox" value="outdoor"><div class="option-content"><div class="option-title">室外機洗浄 <span class="option-price-black">5,500円</span></div></div></label>
          </div>
        </div>
      </div>
    </div>
    <button type="button" class="btn-add" onclick="addAC()">＋ エアコンを追加する</button>
    <button type="button" class="btn-main" onclick="processToStep2()">見積もりを計算する</button>
  </div>

  <div id="step2" class="hidden">
    <h1 class="title">見積もり内容</h1>
    <div id="quote-list" class="quote-box"></div>
    <div class="total-display">合計 <span id="total-price" class="price-red">0</span>円</div>
    <button type="button" class="btn-main" onclick="goToStep(3)">LINEで仮予約の相談をする</button>
    <div class="btn-back" onclick="handleBack()">← 選び直す</div>
  </div>

  <div id="step3" class="hidden">
    <h1 class="title">お客様情報の入力</h1>
    <input type="text" id="u_name" placeholder="お名前">
    <input type="tel" id="u_tel" placeholder="電話番号">
    <input type="text" id="u_addr" placeholder="ご住所">
    <div style="background:#f0fdf4; padding:15px; border-radius:10px; margin: 15px 0;">
      <h3 style="margin:0;">作業目安時間：約<span id="display_time"></span>時間</h3>
    </div>
    <label class="input-label">希望日時</label>
    <div class="date-input-row"><span class="date-input-label">第1希望</span><input type="text" id="u_date1"></div>
    <div class="date-input-row"><span class="date-input-label">第2希望</span><input type="text" id="u_date2"></div>
    <div class="date-input-row"><span class="date-input-label">第3希望</span><input type="text" id="u_date3"></div>
    <textarea id="u_question" placeholder="ご相談事項"></textarea>
    <div class="photo-section">
      <div id="photo-sticker-group">
        <span class="photo-label">型番シールを添付</span>
        <input type="file" id="u_photo_sticker" accept="image/*">
      </div>
      <label class="no-photo-check"><input type="checkbox" id="no-photo-toggle" onchange="togglePhotoInput(this.checked)"> 写真を添付できない</label>
      <div id="no-photo-options" class="hidden">
        <input type="text" id="u_maker" placeholder="メーカー名">
        <input type="file" id="u_photo_main" accept="image/*">
      </div>
    </div>
    <button type="button" class="btn-main" onclick="processToStep4()">内容の確認へ</button>
    <div class="btn-back" onclick="handleBack()">← 戻る</div>
  </div>

  <div id="step4" class="hidden">
    <h1 class="title">最終確認</h1>
    <div class="quote-box">
      <div class="confirm-item"><span class="confirm-label">お名前</span><span class="confirm-value" id="c_name"></span></div>
      <div class="confirm-item"><span class="confirm-label">合計金額</span><span class="confirm-value" id="c_total"></span></div>
    </div>
    <button type="button" id="btn-submit" class="btn-line btn-pulse" onclick="onComplete()">この内容を送信する</button>
    <div class="btn-back" onclick="handleBack()">← 修正する</div>
  </div>
</div>

<script>
const LIFF_ID = "2008817045-0yfL2KnG";
const GAS_URL = "https://script.google.com/macros/s/AKfycbyB49ZpJu9PA-E93TLt5ecVqsU8t6Rm90i3SvCoSBy1Oyq5GWionwCn0dvYPguhwohf/exec";

let acCount = 1;
let globalEstimatedTime = 0;
let summaryTextForLine = "";

const TYPES = {
  'normal': { price: 14500, label: '通常タイプ' },
  'cleaning': { price: 21500, label: 'お掃除機能付き' },
  'unknown': { price: 14500, label: 'わからない' }
};

const OPTIONS = {
  'boukabi': { price: 3300, label: '防カビ加工' },
  'drain': { price: 5500, label: 'ドレンパン洗浄' },
  'outdoor': { price: 5500, label: '室外機洗浄' }
};

window.onload = () => { liff.init({ liffId: LIFF_ID }); };

function goToStep(s) {
  document.querySelectorAll('[id^="step"]').forEach(el => el.classList.add('hidden'));
  document.getElementById('step' + s).classList.remove('hidden');
  window.scrollTo(0,0);
}

function handleBack() { 
  // 簡易的な戻る処理
  const current = Array.from(document.querySelectorAll('[id^="step"]')).find(el => !el.classList.contains('hidden')).id;
  const stepNum = parseInt(current.replace('step', ''));
  if(stepNum > 1) goToStep(stepNum - 1);
}

function selectType(id, val) {
  document.getElementById(`sel-type-${id}`).value = val;
  syncUI(id, val);
}

function syncUI(id, val) {
  const block = document.getElementById(`ac-block-${id}`);
  block.querySelectorAll('.plan-card').forEach(c => c.classList.remove('selected'));
  if(val !== 'unknown') document.getElementById(`card-${val}-${id}`).classList.add('selected');
}

function addAC() {
  acCount++;
  const firstBlock = document.getElementById('ac-block-1');
  const newBlock = firstBlock.cloneNode(true);
  newBlock.id = `ac-block-${acCount}`;
  newBlock.querySelector('.ac-header').innerText = `エアコン ${acCount}台目`;
  newBlock.querySelector('.type-sel').id = `sel-type-${acCount}`;
  newBlock.querySelector('.type-sel').setAttribute('onchange', `syncUI(${acCount}, this.value)`);
  newBlock.querySelector('[id^="card-normal"]').id = `card-normal-${acCount}`;
  newBlock.querySelector('[id^="card-cleaning"]').id = `card-cleaning-${acCount}`;
  newBlock.querySelector(`#card-normal-${acCount}`).setAttribute('onclick', `selectType(${acCount},'normal')`);
  newBlock.querySelector(`#card-cleaning-${acCount}`).setAttribute('onclick', `selectType(${acCount},'cleaning')`);
  document.getElementById('ac-list').appendChild(newBlock);
}

function togglePhotoInput(isNoPhoto) {
  document.getElementById('photo-sticker-group').classList.toggle('hidden', isNoPhoto);
  document.getElementById('no-photo-options').classList.toggle('hidden', !isNoPhoto);
}

function processToStep2() {
  let total = 0;
  summaryTextForLine = "";
  globalEstimatedTime = 0;
  document.querySelectorAll('.ac-item').forEach((el, i) => {
    const tKey = el.querySelector('.type-sel').value;
    total += TYPES[tKey].price;
    globalEstimatedTime += (tKey === 'cleaning') ? (i===0?3:2.5) : (i===0?2:1.5);
    summaryTextForLine += `${i+1}台目: ${TYPES[tKey].label}\n`;
    el.querySelectorAll('.option-checkbox:checked').forEach(chk => {
      total += OPTIONS[chk.value].price;
      summaryTextForLine += ` └ ${OPTIONS[chk.value].label}\n`;
    });
  });
  if (acCount > 1) {
    const disc = (acCount - 1) * 2000;
    total -= disc;
    summaryTextForLine += `複数台割引: -${disc}円\n`;
  }
  document.getElementById('total-price').innerText = total.toLocaleString();
  document.getElementById('display_time').innerText = globalEstimatedTime;
  document.getElementById('quote-list').innerText = summaryTextForLine;
  goToStep(2);
}

function processToStep4() {
  const name = document.getElementById('u_name').value;
  if(!name) return alert("お名前を入力してください");
  document.getElementById('c_name').innerText = name;
  document.getElementById('c_total').innerText = document.getElementById('total-price').innerText + "円";
  goToStep(4);
}

async function onComplete() {
  const btn = document.getElementById('btn-submit');
  btn.innerText = "送信中..."; btn.disabled = true;

  const noPhoto = document.getElementById('no-photo-toggle').checked;
  const file = noPhoto ? document.getElementById('u_photo_main').files[0] : document.getElementById('u_photo_sticker').files[0];
  
  let photoData = null;
  if (file) {
    photoData = await new Promise(resolve => {
      const reader = new FileReader();
      reader.onload = () => resolve(reader.result.split(',')[1]);
      reader.readAsDataURL(file);
    });
  }

  const payload = {
    name: document.getElementById('u_name').value,
    tel: document.getElementById('u_tel').value,
    addr: document.getElementById('u_addr').value,
    date1: document.getElementById('u_date1').value,
    date2: document.getElementById('u_date2').value,
    date3: document.getElementById('u_date3').value,
    quoteDetails: summaryTextForLine,
    totalPrice: document.getElementById('total-price').innerText,
    question: document.getElementById('u_question').value,
    photoData: photoData,
    photoFileName: file ? file.name : null,
    photoMimeType: file ? file.type : null
  };

  try {
    await fetch(GAS_URL, { method: "POST", body: JSON.stringify(payload) });
    const msg = `【見積予約】\nお名前: ${payload.name}様\n合計: ${payload.totalPrice}円\n内容:\n${summaryTextForLine}`;
    if (liff.isInClient()) {
      await liff.sendMessages([{ type: "text", text: msg }]);
      liff.closeWindow();
    } else {
      alert("送信完了しました");
    }
  } catch (e) {
    alert("エラー: " + e);
    btn.disabled = false; btn.innerText = "この内容を送信する";
  }
}
</script>
</body>
</html>
